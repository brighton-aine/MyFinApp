import streamlit as st

def require_login():

    if (
        "user" not in st.session_state
        or
        st.session_state["user"] is None
    ):

        st.warning(
            "Please login first."
        )

        st.stop()

    st.sidebar.markdown(
        f"### 👤 {st.session_state['user']}"
    )

    st.sidebar.divider()